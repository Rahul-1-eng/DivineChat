# Copy this file to ".env" and fill in your own values.

# Port the server listens on (your host usually sets PORT automatically)
PORT=3000

# Local AI model (Ollama) — powers the AI Assistant and the Interview recruiter.
# IMPORTANT FOR DEPLOYMENT: the deployed server has NO Ollama at localhost, so
# the AI features only work if OLLAMA_URL points at a machine that is actually
# running Ollama and is reachable from the server. Options:
#   - Your own PC running Ollama, exposed via a tunnel (e.g. cloudflared/ngrok)
#   - A separate VPS/GPU host running Ollama
# Then set OLLAMA_URL to that public URL (must be reachable over the internet).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# WebAuthn / fingerprint.
# These are now AUTO-DERIVED from the request domain, so fingerprint login works
# on any deployed domain with no config. Leave them unset unless you have an
# unusual proxy setup and need to force exact values:
#   RP_ID  = your domain, no protocol/port, e.g. "chat.mysite.com"
#   ORIGIN = full https URL, e.g. "https://chat.mysite.com"
# RP_ID=
# ORIGIN=

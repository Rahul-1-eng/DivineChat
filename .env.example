# Copy this file to ".env" and fill in your own values.

# Port the server listens on
PORT=3000

# Local AI model (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# WebAuthn / fingerprint — only change these when you deploy.
# RP_ID must be your domain (no protocol, no port), e.g. "chat.mysite.com".
# ORIGIN must be the full https URL, e.g. "https://chat.mysite.com".
# For local development the defaults below are correct.
RP_ID=localhost
ORIGIN=http://localhost:3000
